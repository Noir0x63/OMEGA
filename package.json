{
  "name": "ztap-terminal",
  "version": "3.1.0",
  "private": false,
  "license": "GPL-3.0-only",
  "description": "ZTAP Encrypted Ephemeral Relay — Zero-Knowledge Terminal",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.noir0x63.ztap",
    "productName": "ZTAP Terminal",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      "Tor/**/*",
      "public/**/*",
      "src/server.js",
      "keygen.js",
      "build.js"
    ],
    "win": {
      "target": "portable"
    }
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1"
  }
}
